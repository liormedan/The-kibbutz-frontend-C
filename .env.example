# הקיבוץ – Environment Variables
# העתק ל-.env.development.local לפיתוח מקומי
# הוסף ל-Vercel Environment Variables לפריסה

# ─── Backend (ASP.NET Core REST API) ────────────────
# ה-API רץ כברירת מחדל על 19653 (http) / 19652 (https).
# ודא שכתובת הפרונט מופיעה ב-Cors:AllowedOrigins בצד הבקאנד.
NEXT_PUBLIC_API_URL=http://localhost:19653

# ─── Admin app (external) ───────────────────────────
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# ─── Dev Bypass ─────────────────────────────────────
# כפתור "כניסת מפתחים" מופיע אוטומטית ב-npm run dev.
# true  → מאלץ אותו להופיע גם ב-build ייצור (Vercel preview בלבד!)
# false → נסתר בייצור. השאר false בפרודקשן.
NEXT_PUBLIC_DEV_BYPASS=false

# ─── Dev account (אופציונלי) ────────────────────────
# אם מוגדרים, כפתור כניסת המפתחים יתחבר לבקאנד האמיתי עם החשבון הזה.
# אם הבקאנד לא זמין או הפרטים נדחים — הכפתור נופל אוטומטית לסשן מקומי מדומה,
# כך שהפרונט עובד גם לבד.
#
# ⚠️ אזהרה: משתני NEXT_PUBLIC_* נצרבים לתוך ה-JS שנשלח לדפדפן וגלויים לכל
# מי שפותח את כלי הפיתוח. השתמש אך ורק בחשבון פיתוח ייעודי עם סיסמה
# חד-פעמית — לעולם לא בסיסמה אמיתית שלך. אל תגדיר אותם בפרודקשן.
# NEXT_PUBLIC_DEV_EMAIL=dev@kibbutz.local
# NEXT_PUBLIC_DEV_PASSWORD=change-me-dev-only
